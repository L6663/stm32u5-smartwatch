# Keep source files consistent across Windows/Linux checkouts.
* text=auto

*.c       text eol=lf
*.h       text eol=lf
*.s       text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.py      text eol=lf
*.ps1     text eol=crlf
*.ioc     text eol=lf
*.uvprojx text eol=crlf
*.uvoptx  text eol=crlf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ttf binary
*.bin binary
*.hex binary
*.axf binary
